{
  "name": "ai-agent-os",
  "displayName": "AI Agent OS",
  "description": "AI Agent OS integration for VS Code — autonomous agents with tool use",
  "version": "0.1.0",
  "publisher": "surya-koritala",
  "repository": "https://github.com/surya-koritala/AIagentOS",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["AI", "Other"],
  "activationEvents": ["onCommand:aiAgentOS.chat"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      { "command": "aiAgentOS.chat", "title": "AI Agent OS: Chat" },
      { "command": "aiAgentOS.plan", "title": "AI Agent OS: Plan Task" },
      { "command": "aiAgentOS.explain", "title": "AI Agent OS: Explain Selection" }
    ],
    "keybindings": [
      { "command": "aiAgentOS.chat", "key": "ctrl+shift+a", "mac": "cmd+shift+a" }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  }
}
